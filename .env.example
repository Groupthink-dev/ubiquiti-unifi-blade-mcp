# UniFi controller credentials
UNIFI_HOST=192.168.1.1
UNIFI_USERNAME=admin
UNIFI_PASSWORD=your-password
UNIFI_PORT=443
UNIFI_SITE=default

# Optional: TOTP 2FA secret (base32 encoded)
UNIFI_TOTP_SECRET=

# Enable write operations (block/unblock clients, toggle WLANs, restart devices, etc.)
UNIFI_WRITE_ENABLED=false

# SSL verification (set to false for self-signed certs — common on UniFi)
UNIFI_VERIFY_SSL=false

# Multi-controller support
# UNIFI_CONTROLLERS=home,office
# UNIFI_HOME_HOST=192.168.1.1
# UNIFI_HOME_USERNAME=admin
# UNIFI_HOME_PASSWORD=password
# UNIFI_OFFICE_HOST=10.0.0.1
# UNIFI_OFFICE_USERNAME=admin
# UNIFI_OFFICE_PASSWORD=password

# Transport: stdio (default) or http
UNIFI_MCP_TRANSPORT=stdio

# HTTP transport settings (only used when UNIFI_MCP_TRANSPORT=http)
UNIFI_MCP_HOST=127.0.0.1
UNIFI_MCP_PORT=8781
UNIFI_MCP_API_TOKEN=

# Logging level
UNIFI_LOG_LEVEL=WARNING
